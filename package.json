{
  "name": "@roo-app/woof",
  "version": "0.1.0",
  "description": "A puppy that lives in your terminal and grows with your work - fed by git, kept company by Claude.",
  "author": "Chase Roossin",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/croossin/woof.git"
  },
  "bugs": {
    "url": "https://github.com/croossin/woof/issues"
  },
  "homepage": "https://github.com/croossin/woof#readme",
  "keywords": [
    "cli",
    "tamagotchi",
    "pet",
    "git",
    "claude",
    "terminal",
    "statusline"
  ],
  "bin": {
    "woof": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist dist-test",
    "build": "npm run clean && tsc",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsc --watch",
    "pretest": "tsc -p tsconfig.test.json",
    "test": "node --test dist-test/test/*.test.js",
    "prepare": "tsc",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  }
}
